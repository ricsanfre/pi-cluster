{
  "name": "Grafana",
  "description": "Grafana",
  "vault_secret_ref": "grafana/oauth2",
  "client_id_key": "client-id",
  "client_secret_key": "client-secret",
  "enabled": true,
  "access_type": "CONFIDENTIAL",
  "root_url": "https://grafana.${CLUSTER_DOMAIN}",
  "admin_url": "https://grafana.${CLUSTER_DOMAIN}",
  "base_url": "https://grafana.${CLUSTER_DOMAIN}",
  "redirect_uris": [
    "https://grafana.${CLUSTER_DOMAIN}/login/generic_oauth"
  ],
  "web_origins": [
    "https://grafana.${CLUSTER_DOMAIN}"
  ],
  "standard_flow_enabled": true,
  "direct_access_grants_enabled": true,
  "implicit_flow_enabled": false,
  "service_accounts_enabled": false,
  "full_scope_allowed": true,
  "default_scopes": [
    "web-origins",
    "acr",
    "profile",
    "roles",
    "roles-id-token",
    "email"
  ],
  "optional_scopes": [
    "address",
    "phone",
    "offline_access",
    "microprofile-jwt"
  ]
}
