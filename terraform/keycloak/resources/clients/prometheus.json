{
  "name": "Prometheus",
  "description": "Prometheus - Monitoring and Alerting Toolkit",
  "vault_secret_ref": "prometheus/oauth2",
  "client_id_key": "client-id",
  "client_secret_key": "client-secret",
  "enabled": true,
  "access_type": "CONFIDENTIAL",
  "root_url": "https://prometheus.${CLUSTER_DOMAIN}",
  "admin_url": "https://prometheus.${CLUSTER_DOMAIN}",
  "base_url": "",
  "redirect_uris": [
    "https://prometheus.${CLUSTER_DOMAIN}/*"
  ],
  "web_origins": [
    "https://prometheus.${CLUSTER_DOMAIN}"
  ],
  "standard_flow_enabled": true,
  "direct_access_grants_enabled": true,
  "implicit_flow_enabled": true,
  "service_accounts_enabled": true,
  "full_scope_allowed": true,
  "default_scopes": [
    "web-origins",
    "acr",
    "profile",
    "roles",
    "email"
  ],
  "optional_scopes": [
    "address",
    "phone",
    "offline_access",
    "microprofile-jwt"
  ]
}
