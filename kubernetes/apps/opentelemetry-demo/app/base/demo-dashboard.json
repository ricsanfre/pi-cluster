        "showHeader": true,
        "sortBy": []
      },
      "pluginVersion": "12.2.0",
      "targets": [
        {
          "datasource": {
            "type": "elasticsearch",
            "uid": "elasticsearch"
          },
          "editorMode": "code",
          "format": "table",
            "metrics": [
              {
                "id": "1",
                "type": "logs"
              }
            ],
          "query": "FROM $__index\n| WHERE `service.name` == \"$service\" AND `service.namespace` == \"otel-demo\"\n| KEEP `@timestamp`, severity_text, `body.text`, `scope.name`, trace_id, span_id\n| SORT `@timestamp` DESC\n| LIMIT 100",
          "queryType": "esql",
          "refId": "A"
        }
      ],
      "title": "Log Records (100 recent entries)",
      "transformations": [
        {
          "id": "formatTime",
          "options": {
            "outputFormat": "YYYY-MM-DD HH:mm:ss.SSS",
            "timeField": "@timestamp",
            "timezone": "browser",
            "useTimezone": true
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "includeByName": {},
            "indexByName": {
              "@timestamp": 0,
              "body.text": 3,
              "scope.name": 4,
              "severity_text": 1,
              "span_id": 6,
              "trace_id": 5
            },
            "renameByName": {
              "@timestamp": "Time",
              "body.text": "Message",
              "scope.name": "Logger",
              "severity_text": "Severity",
              "span_id": "Span ID",
              "trace_id": "Trace ID"
            }
          }
        }
      ],
      "type": "table"
    },
