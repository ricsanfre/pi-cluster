      "options": {
        "cellHeight": "sm",
        "showHeader": true
      },
      "pluginVersion": "12.2.0",
      "targets": [
        {
          "datasource": {
            "type": "elasticsearch",
            "uid": "elasticsearch"
          },
          "editorMode": "code",
          "format": "table",
            "metrics": [
              {
                "id": "1",
                "type": "logs"
              }
            ],
          "query": "FROM $__index\n| WHERE `service.name` == \"$service\" AND `service.namespace` == \"otel-demo\"\n| STATS count = COUNT(*) BY severity = severity_text\n| SORT count DESC",
          "queryType": "esql",
          "refId": "A"
        }
      ],
      "title": "Log Records by Severity",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "includeByName": {},
            "indexByName": {
              "count": 1,
              "severity": 0
            },
            "renameByName": {
              "count": "Count",
              "severity": "Severity"
            }
          }
        }
      ],
      "type": "table"
    },
    {
